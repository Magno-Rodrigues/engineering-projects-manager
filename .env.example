# Ambiente
ENV=production

# Application
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/engineering_projects
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/engineering_projects_test

# PostgreSQL (for Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=engineering_projects

# Email Outlook/Exchange (Windows development only, used by exchangelib)
# Leave blank to fall back to SMTP automatically
OUTLOOK_EMAIL=seu_email@empresa.com

# Email SMTP (Gmail, SendGrid, Outlook.com, etc.)
# Used when ENV=production or when running on Linux/macOS
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_app
MAIL_DEFAULT_SENDER=seu_email@gmail.com

# --- Exemplos de outros provedores SMTP ---
# SendGrid:
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.xxxxxxxxxxxxx
#
# Outlook.com:
# MAIL_SERVER=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USERNAME=seu_email@outlook.com
# MAIL_PASSWORD=sua_senha
